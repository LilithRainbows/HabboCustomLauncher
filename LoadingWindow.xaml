<Window x:Class="LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
                Title="Loading" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" FontSize="20" Topmost="True" ShowInTaskbar="False" WindowStyle="None" Foreground="White" AllowsTransparency="True">
    <Window.Background>
        <SolidColorBrush Color="#FF6E0A3C" Opacity="0.9"/>
    </Window.Background>
    <Grid KeyboardNavigation.TabNavigation="None" KeyboardNavigation.ControlTabNavigation="None" KeyboardNavigation.DirectionalNavigation="None">
        <TextBlock x:Name="LoadingTB" Text="Loading Habbo ." Margin="40,20"/>
        <TextBlock x:Name="HiddenLoadingTB" Text="Loading Habbo ..." Margin="40,20" Visibility="Hidden"/>
    </Grid>
</Window>